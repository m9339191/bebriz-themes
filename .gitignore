admin/

# Shopify theme source (sellable product - do NOT publish to public repo)
# themes/volt has its own standalone git repo for version control.
# The sales page (index.html) is hand-maintained here and tracked; everything
# else in themes/volt/ (the theme source files) stays excluded.
themes/volt/*
!themes/volt/index.html
volt-theme.zip
volt-theme-*.zip

